{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/9-Security/IR_Collect/docs/schemas/correlation_v1.schema.json",
  "title": "IR_Collect correlation_v1",
  "description": "Output of `IR_Collect.exe -correlate` — cross-host shared-entity and temporal correlation.",
  "type": "object",
  "required": ["export_schema", "generated_at", "tool_name", "tool_version", "host_count", "hosts", "shared_entities", "temporal_correlations"],
  "properties": {
    "export_schema": { "const": "correlation_v1" },
    "generated_at": { "type": "string", "description": "UTC ISO-8601 generation time." },
    "tool_name": { "type": "string" },
    "tool_version": { "type": "string", "description": "Major.Minor.Build of the producing IR_Collect build." },
    "host_count": { "type": "integer" },
    "ready_hosts": { "type": "integer" },
    "skipped_hosts": { "type": "integer" },
    "bucket_minutes": { "type": "integer", "description": "Temporal-correlation time-bucket size." },
    "entity_types": { "type": "array", "items": { "type": "string" } },
    "hosts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["host", "case_id", "fact_count"],
        "properties": {
          "host": { "type": "string" },
          "case_id": { "type": "string" },
          "fact_count": { "type": "integer" },
          "evidence_digest": { "type": "string" },
          "evidence_file_count": { "type": "integer" }
        }
      }
    },
    "shared_entities": {
      "type": "array",
      "description": "Entities observed on more than one host.",
      "items": {
        "type": "object",
        "required": ["entity_type", "value", "fact_count", "host_count", "hosts"],
        "properties": {
          "entity_type": { "type": "string" },
          "value": { "type": "string" },
          "fact_count": { "type": "integer" },
          "host_count": { "type": "integer" },
          "hosts": { "type": "array", "items": { "type": "string" } },
          "sources": { "type": "array", "items": { "type": "string" } },
          "first_seen": { "type": "string", "description": "ISO-8601 UTC or empty." },
          "last_seen": { "type": "string", "description": "ISO-8601 UTC or empty." }
        }
      }
    },
    "temporal_correlations": {
      "type": "array",
      "description": "Same entity seen in the same time bucket on >=2 hosts.",
      "items": {
        "type": "object",
        "required": ["entity_type", "value", "host_count", "hosts"],
        "properties": {
          "entity_type": { "type": "string" },
          "value": { "type": "string" },
          "fact_count": { "type": "integer" },
          "host_count": { "type": "integer" },
          "hosts": { "type": "array", "items": { "type": "string" } },
          "bucket_start": { "type": "string" },
          "bucket_end": { "type": "string" }
        }
      }
    }
  }
}
