# Public mirror: root READMEs, selected docs; binary via GitHub Releases only.
/*
!/.gitattributes
!/.gitignore
!/README.md
!/README.zh-TW.md
!/docs/
/docs/*
!/docs/README.md
!/docs/FIELD_SOP.md
!/docs/FIELD_SOP.zh-TW.md
!/docs/USER_MANUAL.md
!/docs/USER_MANUAL.zh-TW.md
!/docs/SPEC.md
!/docs/CHANGELOG.md
