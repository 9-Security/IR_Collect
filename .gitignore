# IR_Collect — source is tracked; build outputs, runtime state, and collected
# evidence are NOT. (This repo previously published binaries only; it is now open source.
# Binaries continue to ship via GitHub Releases.)

# ---- Build outputs ----
*.exe
*.zip
*.zip.sha256
/dist/

# ---- Runtime / user state (may contain API keys, endpoints, or real evidence) ----
config.ini
/logs/
/IR_Output_*/

# ---- Test / verification scratch dirs (may hold real artifact data) ----
/tmp_*/

# ---- Third-party reference tools (Eric Zimmerman tools for Phase 2.2 diff
#      validation) — downloaded locally, never redistributed via this repo ----
/tools/

# ---- Assistant working notes (kept under ~/.claude, never in the repo) ----
/memory/

# ---- IDE / OS cruft ----
.vs/
*.user
Thumbs.db
